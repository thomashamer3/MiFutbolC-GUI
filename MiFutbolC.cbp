<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="MiFutbolC" />
		<Option pch_mode="2" />
		<Option compiler="gcc-msys2-mingw64" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/MiFutbolC" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc-msys2-mingw64" />
				<Compiler>
					<Add option="-fexpensive-optimizations" />
					<Add option="-flto" />
					<Add option="-Wextra" />
					<Add option="-Wall" />
					<Add option="-std=c23" />
					<Add option="-s" />
					<Add option="-fstack-protector" />
					<Add option="-ffunction-sections" />
					<Add option="-fdata-sections" />
					<Add option="-isystem" />
					<Add option="-mtune=native" />
					<Add directory="C:/msys64/mingw64/include" />
				</Compiler>
				<Linker>
					<Add option="-O2" />
					<Add option="-flto" />
					<Add option="-s" />
					<Add option="-static-libstdc++" />
					<Add option="-static-libgcc" />
					<Add option="-static" />
					<Add option="-Wl,--gc-sections" />
					<Add directory="C:/msys64/mingw64/lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/MiFutbolC" prefix_auto="1" extension_auto="1" />
